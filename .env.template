# GitHub Activity Logger (v2) — copy to .env and fill in values

# Server (Switchboard port 3040 — see ../Switchboard/LOCALHOSTS_LIST.md)
HOST=127.0.0.1
PORT=3040

# GitHub webhook + backfill
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=your_github_username_or_org_here
# Optional: single-repo backfill; leave unset for all repos
GITHUB_REPO=your_repository_name_here

# Local data (SQLite path added in G1)
DATA_DIR=./data

# Optional read API auth when exposed via Tailscale
# GITHUB_LOGGER_TOKEN=

# Legacy v1 — set false during rework; removed from hot path in G1
NOTION_SYNC=false

# --- Legacy v1 (optional until archive) ---
# NOTION_API_KEY=your_notion_api_key_here
# NOTION_COMMIT_FROM_GITHUB_LOG_ID=your_notion_commit_database_id_here
# OPENAI_API_KEY=your_openai_api_key_here
